---
services:
  beszel-agent:
    image: {{ beszel_agent_image }}
    container_name: beszel-agent
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./beszel_agent_data:/var/lib/beszel-agent
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      LISTEN: "{{ beszel_agent_port }}"
      KEY: "{{ beszel_hub_key }}"
