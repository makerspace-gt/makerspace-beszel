---
services:
  beszel-agent:
    image: {{ beszel_agent_image }}
    container_name: beszel-agent
    restart: unless-stopped
    network_mode: host
    volumes:
      - ./beszel_agent_data:/var/lib/beszel-agent
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      LISTEN: "{{ beszel_agent_port }}"
      KEY: "{{ beszel_hub_key }}"
    # scratch-based image: no shell/curl, so use the agent's built-in `health` command.
    # Verifies the agent process is healthy locally (not that it's reachable from the hub).
    healthcheck:
      test: ["CMD", "/agent", "health"]
      interval: 120s
      timeout: 5s
      retries: 3
      start_period: 15s
